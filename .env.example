# Copy this file to .env and fill in the values you have.
# Both are optional — the pipeline runs without them, just with tighter
# rate limits and keyword-based (instead of LLM) trend clustering.

# Raises GitHub API limits from 60/hr to 5000/hr — more search queries,
# more builder profile enrichment per run.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Enables LLM trend clustering + "why it's rising" summaries (Gemini 2.5 Flash).
# Without it, trends fall back to keyword grouping.
# Create one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Server port (default 4242)
PORT=
