# Copy this file to .env and fill in the values you have.
# All of these are optional — the pipeline runs without them, just with
# tighter rate limits, keyword-based trend clustering, and no Reddit signal.

# Raises GitHub API limits from 60/hr to 5000/hr — more search queries,
# more builder profile enrichment per run.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Enables LLM trend clustering + "why it's rising" summaries (Gemini 2.5 Flash).
# Without it, trends fall back to keyword grouping.
# Create one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Enables the Reddit connector (r/programming, r/ExperiencedDevs, r/devops).
# Reddit's free JSON API blocks datacenter/cloud IPs outright, so these are
# required (not just rate-limit relief) for this connector to work at all.
# Create a free "script" app at: https://www.reddit.com/prefs/apps
#   → name: anything · type: script · redirect uri: http://localhost:4242
#   → REDDIT_CLIENT_ID is the string under the app name; REDDIT_CLIENT_SECRET is the "secret" field
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Server port (default 4242)
PORT=
